# OpenRouter API Credentials
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override default OpenRouter model (default is meta-llama/llama-3.1-8b-instruct:free)
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Local filesystem buckets used by the downloader and plaintext processor.
# These can later be replaced by S3/GCS adapters while keeping DB object URIs stable.
ARCHIVE_RAW_BUCKET_DIR=bucket/raw
ARCHIVE_TEXT_BUCKET_DIR=bucket/text
