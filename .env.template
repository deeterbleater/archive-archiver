# OpenRouter API Credentials
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override default OpenRouter model (default is meta-llama/llama-3.1-8b-instruct:free)
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Local filesystem buckets used by the downloader and plaintext processor.
# These can later be replaced by S3/GCS adapters while keeping DB object URIs stable.
ARCHIVE_RAW_BUCKET_DIR=bucket/raw
ARCHIVE_QUARANTINE_BUCKET_DIR=bucket/quarantine
ARCHIVE_TEXT_BUCKET_DIR=bucket/text
ARCHIVE_CORPUS_BUCKET_DIR=bucket/corpora

# Optional: explicit ClamAV scanner path. If unset, the downloader looks for
# clamscan on PATH. Untrusted downloads fail closed when no scanner is available.
# ARCHIVE_CLAMSCAN_BIN=/usr/bin/clamscan

# Optional: archive local raw originals to S3-compatible object storage after
# plaintext extraction succeeds. Credentials are read from ~/.s3 by default.
# ARCHIVE_RAW_TO_S3=1
# ARCHIVE_S3_CONFIG=/root/.s3
# ARCHIVE_S3_BUCKET=your-vultr-object-storage-bucket
# ARCHIVE_S3_REGION=us-east-1
# ARCHIVE_RAW_OBJECT_PREFIX=raw-originals
