#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
PYTHON="${REPO_DIR}/venv/bin/python"

if [ ! -x "${PYTHON}" ]; then
  PYTHON="python3"
fi

cd "${REPO_DIR}"

if [ "${1:-}" = "--no-tmux" ]; then
  shift
  exec "${PYTHON}" cli.py agent "$@"
fi

if [ "$#" -gt 0 ] || [ "${ALGE_NO_TMUX:-0}" = "1" ] || ! command -v tmux >/dev/null 2>&1 || [ ! -t 0 ] || [ ! -t 1 ]; then
  exec "${PYTHON}" cli.py agent "$@"
fi

SESSION_NAME="${ALGE_TMUX_SESSION:-alge}"
DASHBOARD_INTERVAL="${ALGE_DASHBOARD_INTERVAL:-2}"
DASHBOARD_HEIGHT="${ALGE_DASHBOARD_HEIGHT:-5}"
DASHBOARD_CMD="cd '${REPO_DIR}' && exec '${PYTHON}' cli.py dashboard --watch --interval '${DASHBOARD_INTERVAL}'"
AGENT_CMD="cd '${REPO_DIR}' && ALGE_NO_BANNER=1 ALGE_TMUX_MANAGED=1 ALGE_TMUX_SESSION='${SESSION_NAME}' exec '${PYTHON}' cli.py agent"

if ! tmux has-session -t "${SESSION_NAME}" 2>/dev/null; then
  tmux new-session -d -s "${SESSION_NAME}" -c "${REPO_DIR}" "${DASHBOARD_CMD}"
  tmux split-window -v -p 80 -t "${SESSION_NAME}:0.0" -c "${REPO_DIR}" "${AGENT_CMD}"
  tmux resize-pane -t "${SESSION_NAME}:0.0" -y "${DASHBOARD_HEIGHT}"
  tmux select-pane -t "${SESSION_NAME}:0.1"
fi

if [ -n "${TMUX:-}" ]; then
  exec tmux switch-client -t "${SESSION_NAME}"
fi

exec tmux attach-session -t "${SESSION_NAME}"
